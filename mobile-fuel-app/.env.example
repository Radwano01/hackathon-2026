# Copy this file to .env (do NOT commit your real key)
# Add your Google Maps / Places API key here
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Optional: backend base URL
EXPO_PUBLIC_API_BASE_URL=

# If you run the local places proxy, point the app to it (default below)
EXPO_PUBLIC_PLACES_PROXY_URL=http://localhost:4000